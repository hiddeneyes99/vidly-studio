# ============================================================
# Vidly Studio — environment variables
# Copy needed values into Vercel Project Settings → Environment Variables
# ============================================================

# --- BACKEND (server-only, do NOT expose to browser) ---

# Gemini API key — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# JWT signing secret — generate a 64+ char random hex string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Login credentials — what you'll type into the login screen
APP_USERNAME=
APP_PASSWORD=

# --- FRONTEND (browser-exposed, must be prefixed VITE_) ---

# Supabase — from Supabase Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# YouTube Data API v3 key — https://console.cloud.google.com/apis/credentials
VITE_YOUTUBE_API_KEY=

# Same Gemini key above, exposed to the browser only if any client-side
# feature still calls Gemini directly. Safe to leave blank if you only
# use server-side AI routes.
VITE_GEMINI_API_KEY=
